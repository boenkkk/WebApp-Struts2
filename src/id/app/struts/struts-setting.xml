<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE struts PUBLIC "-//Apache Software Foundation//DTD Struts Configuration 2.0//EN" "http://struts.apache.org/dtds/struts-2.0.dtd">
<struts>
	
	<package name="setting" namespace="/setting" extends="default">		
		<interceptors>
			<interceptor class="id.util.interceptor.LoginInterceptor" name="loginInterceptor">
			</interceptor>
			<interceptor-stack name="loginStack">
				<interceptor-ref name="loginInterceptor"/>
				<interceptor-ref name="defaultStack" />
			</interceptor-stack>
		</interceptors>
		
		<global-results>
			<result name="login" type="redirectAction">
				<param name="actionName">login</param>
				<param name="namespace">/</param>
			</result>
		</global-results>
		
		<!-- Start Data User -->
		<action name="data-user">
			<interceptor-ref name="loginStack"></interceptor-ref>
			<result>/WEB-INF/pages/menu/DataUser.jsp</result>
		</action>
		<!-- End Data User -->
	</package>
	
	<package name="settingJson" namespace="/setting" extends="json-default">
		<interceptors>
			<interceptor-stack name="defaultStack">
				<interceptor-ref name="json">
					<param name="enableSMD">true</param>
				</interceptor-ref>
			</interceptor-stack>
		</interceptors>
		<default-interceptor-ref name="defaultStack" />
		
		<!-- Start Log Server -->
		<!-- <action name="ProsesLunasTunggakanPerDist" class="id.pln.icon.p2apst.action.penarikanData.PelunasanTunggakan" method="LunasTunggakanPerDist">
			<result type="json"></result>
		</action> -->
		<!-- End Log Server -->
	</package>
	
</struts>